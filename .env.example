# =====================================================
# CONFIGURAÇÃO DO AMBIENTE - SISTEMA CSM
# =====================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA faça commit deste arquivo com valores reais!
# =====================================================

# =====================================================
# SUPABASE
# =====================================================

# URL do projeto Supabase (encontrada em: Supabase Dashboard > Project Settings > General)
# Formato: https://xxxxx.supabase.co ou apenas xxxxx (project ref)
VITE_SUPABASE_URL=https://cfybsocrydeziibonvbd.supabase.co

# Chave anônima do Supabase (pode ser exposta no cliente)
# Encontrada em: Supabase Dashboard > Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# SEGURANÇA - IMPORTANTE
# =====================================================
# NUNCA adicione VITE_SUPABASE_SERVICE_ROLE_KEY aqui!
# A service role key concede acesso total ao banco e deve ser usada:
# - Apenas em Edge Functions do Supabase (server-side)
# - Nunca no código cliente (frontend)
#
# Para operações administrativas no frontend, use Edge Functions:
# - supabase/functions/admin-create-user
# - supabase/functions/admin-reset-password

# =====================================================
# VARIÁVEIS OPCIONAIS
# =====================================================

# URL de produção (para deploy no Vercel/GitHub Pages)
# VITE_BASE_URL=/secretaria_escola_csm