# URL do projeto Supabase (ex: https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Chave anônima do Supabase (pode ser exposta no cliente)
# Encontrada em: Supabase Dashboard > Project Settings > API > Project API keys
VITE_SUPABASE_ANON_KEY=

# NOTA DE SEGURANÇA:
# NUNCA adicione VITE_SUPABASE_SERVICE_ROLE_KEY aqui!
# A service role key deve ser usada APENAS em Edge Functions ou backend.
# Para instruções sobre como configurar Edge Functions, veja:
# - src/lib/supabase.js
# - src/lib/admin-service.js
